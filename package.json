{
  "name": "vscode-sidebar-notes",
  "displayName": "Sticky Sidebar Notes",
  "description": "Markdown sidebar that persists across restarts and is writable by Claude. Successor to the original Sidebar Notes.",
  "version": "0.1.2",
  "publisher": "deviationlabs",
  "icon": "media/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abutala/homely_vibes.git",
    "directory": "VSCodeSidebarNotes"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Notebooks",
    "Other"
  ],
  "keywords": [
    "notes",
    "markdown",
    "sidebar",
    "claude",
    "scratchpad"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sidebarNotes",
          "title": "Sidebar Notes",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "sidebarNotes": [
        {
          "type": "webview",
          "id": "sidebarNotes.view",
          "name": ""
        }
      ]
    },
    "commands": [
      {
        "command": "sidebarNotes.openFile",
        "title": "Open Notes File",
        "icon": "media/open.svg"
      },
      {
        "command": "sidebarNotes.clear",
        "title": "Clear Notes",
        "icon": "media/clear.svg"
      },
      {
        "command": "sidebarNotes.openStyles",
        "title": "Edit Notes Styles",
        "icon": "media/styles.svg"
      },
      {
        "command": "sidebarNotes.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sidebarNotes.refresh",
          "when": "view == sidebarNotes.view",
          "group": "navigation@1"
        },
        {
          "command": "sidebarNotes.openStyles",
          "when": "view == sidebarNotes.view",
          "group": "navigation@2"
        },
        {
          "command": "sidebarNotes.clear",
          "when": "view == sidebarNotes.view",
          "group": "navigation@3"
        },
        {
          "command": "sidebarNotes.openFile",
          "when": "view == sidebarNotes.view",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Sidebar Notes",
      "properties": {
        "sidebarNotes.fileName": {
          "type": "string",
          "default": "notes.md",
          "description": "Workspace-relative path of the markdown file to display."
        },
        "sidebarNotes.globalFile": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a global notes file. Used when no workspace folder is open. Leave blank to disable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "package-vsix": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "publish-cursor": "ovsx publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.1",
    "ovsx": "^0.9.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "marked": "^12.0.2"
  }
}
